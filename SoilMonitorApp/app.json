{
  "expo": {
    "name": "Soil Monitor",
    "slug": "soil-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rvce.soilmonitor"
    },
    "android": {
      "package": "com.rvce.soilmonitor",
      "adaptiveIcon": {
        "backgroundColor": "#0d1117",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow Soil Monitor to access your microphone for voice AI commands."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e6100f1d-20c7-42db-9b62-19396b542dee"
      }
    },
    "owner": "praneelka12"
  }
}
