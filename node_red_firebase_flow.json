[
  {
    "id": "fb-readings-latest",
    "type": "tab",
    "label": "MQTT → Firebase",
    "disabled": false,
    "info": "Bridges soil/readings and soil/alerts from MQTT to Firebase Realtime Database via REST API"
  },
  {
    "id": "mqtt-in-readings",
    "type": "mqtt in",
    "z": "fb-readings-latest",
    "name": "soil/readings",
    "topic": "soil/readings",
    "qos": "0",
    "datatype": "json",
    "broker": "",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 130,
    "y": 100,
    "wires": [["parse-reading"]]
  },
  {
    "id": "parse-reading",
    "type": "function",
    "z": "fb-readings-latest",
    "name": "Prepare Firebase payload",
    "func": "// Attach server-side timestamp if missing\nif (!msg.payload.timestamp) {\n    msg.payload.timestamp = Date.now();\n}\n\n// Clone for latest (PUT - overwrites)\nvar latestMsg = {\n    payload: JSON.stringify(msg.payload),\n    headers: { 'Content-Type': 'application/json' },\n    url: 'https://soil-monitoring-8b69c-default-rtdb.firebaseio.com/soil/readings/latest.json'\n};\n\n// Clone for history (POST - appends with Firebase auto-key)\nvar historyMsg = {\n    payload: JSON.stringify(msg.payload),\n    headers: { 'Content-Type': 'application/json' },\n    url: 'https://soil-monitoring-8b69c-default-rtdb.firebaseio.com/soil/readings/history.json'\n};\n\nreturn [latestMsg, historyMsg];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 350,
    "y": 100,
    "wires": [["http-put-latest"], ["http-post-history"]]
  },
  {
    "id": "http-put-latest",
    "type": "http request",
    "z": "fb-readings-latest",
    "name": "PUT /latest",
    "method": "PUT",
    "ret": "txt",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 620,
    "y": 60,
    "wires": [["debug-latest"]]
  },
  {
