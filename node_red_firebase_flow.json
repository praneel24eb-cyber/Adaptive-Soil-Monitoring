[
  {
    "id": "fb-readings-latest",
    "type": "tab",
    "label": "MQTT → Firebase",
    "disabled": false,
    "info": "Bridges soil/readings and soil/alerts from MQTT to Firebase Realtime Database via REST API"
  },
  {
    "id": "mqtt-broker-local",
    "type": "mqtt-broker",
    "name": "Localhost MQTT",
    "broker": "localhost",
    "port": "1883",
    "clientid": "nodered-soil-bridge",
    "autoConnect": true,
    "usetls": false,
    "protocolVersion": "4",
    "keepalive": "60",
    "cleansession": true,
    "autoUnsubscribe": true,
    "birthTopic": "",
    "birthQos": "0",
    "birthPayload": "",
    "birthMsg": {},
    "closeTopic": "",
    "closeQos": "0",
    "closePayload": "",
    "closeMsg": {},
    "willTopic": "",
