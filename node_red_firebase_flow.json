  {
    "id": "mqtt-in-alerts",
    "type": "mqtt in",
    "z": "fb-readings-latest",
    "name": "soil/alerts",
    "topic": "soil/alerts",
    "qos": "0",
    "datatype": "json",
    "broker": "",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 130,
    "y": 220,
    "wires": [["prepare-alert"]]
  },
  {
    "id": "prepare-alert",
    "type": "function",
    "z": "fb-readings-latest",
    "name": "Prepare alert payload",
    "func": "if (!msg.payload.timestamp) {\n    msg.payload.timestamp = Date.now();\n}\nmsg.payload = JSON.stringify(msg.payload);\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.url = 'https://soil-monitoring-8b69c-default-rtdb.firebaseio.com/soil/alerts.json';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 350,
    "y": 220,
    "wires": [["http-post-alert"]]
  },
